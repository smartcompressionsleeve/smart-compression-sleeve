# Copy this file to .env and fill in your real values.
# The .env file is gitignored — never commit it.

# Supabase project URL (find at: supabase.com → your project → Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key — DO NOT put the service_role key here.
# The anon key is safe to ship; Row Level Security policies protect data.
SUPABASE_ANON_KEY=your-supabase-anon-key-here
